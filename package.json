{
  "name": "next-supabase-prisma-vercel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && prisma migrate deploy && next build",
    "prisma:gen": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:restart": "supabase restart",
    "start": "next start",
    "lint": "biome check --write ./src",
    "format": "biome format --write",
    "tsc": "tsc --noEmit",
    "tsr": "tsr --write 'next\\.config\\.ts$' 'vitest\\.config\\.ts$' 'src/env\\.ts$' 'src/app/.*page\\.tsx$' 'src/app/.*layout\\.tsx$' 'src/app/.*route\\.ts$' 'src/.*\\.test\\.(ts|tsx)$' '\\.next/types/validator\\.ts$'",
    "ci": "pnpm format && pnpm lint && pnpm tsc"
  },
  "dependencies": {
    "@prisma/client": "6.16.2",
    "@supabase/ssr": "0.8.0",
    "@supabase/supabase-js": "2.90.1",
    "clsx": "2.1.1",
    "next": "16.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@tailwindcss/postcss": "4.1.18",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.0.9",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "autoprefixer": "10.4.23",
    "jsdom": "27.4.0",
    "prisma": "6.16.2",
    "tailwindcss": "4.1.18",
    "tsr": "1.3.4",
    "typescript": "5.9.3",
    "vitest": "4.0.17"
  }
}
